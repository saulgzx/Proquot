# Database
DATABASE_URL=postgresql://usuario:password@host:5432/proquot

# JWT
JWT_SECRET=CAMBIA_ESTO_POR_AL_MENOS_64_CARACTERES_RANDOM

# Server
PORT=3001
NODE_ENV=development
APP_VERSION=1.0.0

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_TAB_QNAP=Hoja 1
GOOGLE_SHEETS_TAB_AXIS=Hoja 2
GOOGLE_SHEETS_TAB_STOCK=Stock
GOOGLE_SHEETS_SYNC_HOURS=12
GOOGLE_API_TIMEOUT_MS=30000
GOOGLE_API_RETRIES=3
GOOGLE_API_RETRY_DELAY_MS=300

# Session TTL
SESSION_TTL_MIN=10
ADMIN_SESSION_TTL_MIN=43200
ADMIN_JWT_EXPIRES_IN=30d

# Rate limiting
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MIN=15
LOGIN_RATE_LIMIT_BYPASS_USERS=

# Cache TTL
STOCK_CACHE_TTL_SEC=120
STOCK_CATALOG_CACHE_TTL_SEC=180
OSO_ORDERS_CACHE_TTL_SEC=120

# PDF
PUPPETEER_EXECUTABLE_PATH=
CHROME_BIN=
